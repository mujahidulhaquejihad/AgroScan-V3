{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Train all (leaf + 3 disease models)",
      "type": "shell",
      "command": "python",
      "args": ["-u", "-m", "agrovet.train_all"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Run API + Web app",
      "type": "shell",
      "command": "python",
      "args": ["-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
